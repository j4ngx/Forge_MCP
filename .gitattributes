# Auto-detect text files and ensure LF line endings
* text=auto eol=lf

# Shell scripts
*.sh text eol=lf

# Python
*.py text eol=lf

# Config files
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.jsonc text eol=lf

# Markdown
*.md text eol=lf

# Lock files — treat as generated
uv.lock linguist-generated=true
